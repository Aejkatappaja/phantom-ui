	</div>
</section>

<section class="repeat-section">
	<div class="section-intro">
		<h2>Repeat mode</h2>
		<p class="muted">Generate multiple skeleton rows from a single template with <code>count</code> and <code>count-gap</code>.</p>
	</div>

	<div class="repeat-controls">
		<div class="ctrl-group">
			<span class="ctrl-label">Count <span class="ctrl-val" id="v-count">5</span></span>
			<input type="range" id="r-count" min="1" max="10" step="1" value="5" />
		</div>
		<div class="ctrl-group">
			<span class="ctrl-label">Gap <span class="ctrl-val" id="v-gap">0px</span></span>
			<input type="range" id="r-gap" min="0" max="24" step="1" value="0" />
		</div>
	</div>

	<div class="repeat-grid">
		<div class="repeat-card">
			<div class="table-head" data-shimmer-ignore>
				<span class="th" style="width:32px"></span>
				<span class="th">Name</span>
				<span class="th">Email</span>
				<span class="th" style="width:60px">Role</span>
			</div>
			<phantom-ui class="count-target" count="5" count-gap="0">
				<div class="table-row">
					<img class="dot-avatar" src="https://i.pravatar.cc/64?img=68" alt="" width="32" height="32" />
					<span>John Doe</span>
					<span>john@acme.io</span>
					<span class="role-badge">Admin</span>
				</div>
			</phantom-ui>
			<div class="loaded-rows">
				<div class="table-row">
					<img class="dot-avatar" src="https://i.pravatar.cc/64?img=33" alt="" width="32" height="32" />
					<span>Alex Rivera</span>
					<span>alex@acme.io</span>
					<span class="role-badge">Dev</span>
				</div>
				<div class="table-row">
					<img class="dot-avatar" src="https://i.pravatar.cc/64?img=25" alt="" width="32" height="32" />
					<span>Priya Sharma</span>
					<span>priya@acme.io</span>
					<span class="role-badge">Dev</span>
				</div>
				<div class="table-row">
					<img class="dot-avatar" src="https://i.pravatar.cc/64?img=15" alt="" width="32" height="32" />
					<span>Marcus Lee</span>
					<span>marcus@acme.io</span>
					<span class="role-badge">Design</span>
				</div>
				<div class="table-row">
					<img class="dot-avatar" src="https://i.pravatar.cc/64?img=51" alt="" width="32" height="32" />
					<span>Emma Wilson</span>
					<span>emma@acme.io</span>
					<span class="role-badge">PM</span>
				</div>
