	.comment.last { border-bottom: none; }
	.comment p { margin-top: 4px; }

	.chat-card { padding: 0; display: flex; flex-direction: column; }

	.chat-header {
		display: flex; align-items: center; gap: 10px;
		padding: 14px 16px;
		border-bottom: 1px solid var(--border);
	}

	.chat-header .dot-avatar {
		width: 28px; height: 28px;
		background: var(--accent-dim);
	}

	.chat-header strong { font-size: 13px; display: block; }
	.chat-header .small { display: block; line-height: 1.3; }

	.chat-messages {
		padding: 14px 16px 16px;
		display: flex; flex-direction: column; gap: 10px;
	}

	.msg {
		display: flex; align-items: flex-start; gap: 8px;
	}

	.msg-other { align-self: flex-start; }
	.msg-self { align-self: flex-end; justify-content: flex-end; }

	.msg-avatar {
		width: 24px; height: 24px; border-radius: 50%;
		background: var(--bg-raised); flex-shrink: 0; margin-top: 2px;
		object-fit: cover;
	}

	.msg-bubble {
		background: var(--bg-raised);
		border: 1px solid var(--border);
		border-radius: 10px; border-top-left-radius: 3px;
		padding: 8px 12px;
		max-width: 240px;
	}

	.msg-bubble.self {
		background: rgba(122,162,247,0.12);
		border-color: rgba(122,162,247,0.2);
		border-radius: 10px; border-top-right-radius: 3px;
	}

	.msg-name {
		font-size: 11px; font-weight: 600; color: var(--accent);
		display: block; margin-bottom: 3px;
	}

	.msg-bubble p {
		font-size: 13px; line-height: 1.5; margin: 0;
		color: var(--text);
	}

	.msg-time {
		font-size: 10px; display: block; margin-top: 4px;
		text-align: right;
	}

	.metrics-card { display: flex; flex-direction: column; gap: 0; }

	.metrics-title {
		font-size: 15px; font-weight: 600; margin-bottom: 16px !important;
	}

	.metric-row { margin-bottom: 12px; }
	.metric-row:last-child { margin-bottom: 0; }

	.metric-head {
		display: flex; justify-content: space-between; align-items: center;
		margin-bottom: 6px;
	}

	.metric-label {
		font-size: 12px; color: var(--muted); font-weight: 400;
	}

	.metric-value {
		font-size: 12px; font-family: var(--mono); color: var(--text);
		font-weight: 500;
	}

	.meter {
		width: 100%; height: 6px; border-radius: 3px;
		background: var(--bg-raised);
		overflow: hidden;
	}

	.meter-fill {
		height: 100%; border-radius: 3px;
		background: var(--accent);
		transition: width 0.4s ease, opacity 0.3s;
	}

	.metric-row:nth-child(3) .meter-fill { background: var(--green); }
	.metric-row:nth-child(4) .meter-fill { background: var(--orange); }
	.metric-row:nth-child(5) .meter-fill { background: #bb9af7; }

	.product-card { padding: 0; overflow: hidden; }

	.product-img {
		width: 100%; height: 140px;
		background: var(--bg-raised);
		object-fit: cover; display: block;
	}

	.product-body { padding: 14px 16px 16px; }

	.product-cat {
		display: block; font-size: 11px; text-transform: uppercase;
		letter-spacing: 0.8px; margin-bottom: 4px; font-weight: 500;
	}

	.product-name { font-size: 15px; margin-bottom: 8px; }

	.stars {
		display: flex; align-items: center; gap: 1px;
		margin-bottom: 12px;
	}

	.star {
		font-size: 14px; line-height: 1;
	}

	.star.filled { color: var(--orange); }
	.star.dim { color: var(--dim); }

	.star-count {
		margin-left: 6px;
	}

	.product-footer {
		display: flex; align-items: center; justify-content: space-between;
		padding-top: 12px; border-top: 1px solid var(--border);
	}

	.product-price {
		font-family: var(--mono); font-size: 20px; font-weight: 700;
		color: var(--text);
	}

	.cta-sm {
		padding: 7px 16px;
		background: var(--accent); color: var(--bg-deep);
		border: none; border-radius: 8px;
		font-family: var(--font); font-weight: 600; font-size: 12px;
		cursor: pointer; transition: opacity 0.2s;
	}

	.cta-sm:hover { opacity: 0.9; }

	.player-card {
		display: flex; flex-direction: column; gap: 14px;
	}

	.player-top {
		display: flex; align-items: center; gap: 14px;
	}

	.album-art {
		width: 64px; height: 64px; border-radius: 8px;
		background: var(--bg-raised); flex-shrink: 0;
		object-fit: cover;
	}

	.player-info { flex: 1; min-width: 0; }

	.player-song {
		font-size: 15px; font-weight: 600; margin-bottom: 2px;
		white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
	}

	.player-progress { display: flex; flex-direction: column; gap: 4px; }

	.progress-bar {
		width: 100%; height: 4px; border-radius: 2px;
		background: var(--bg-raised); overflow: hidden;
	}

	.progress-fill {
		height: 100%; border-radius: 2px;
		background: var(--accent);
		transition: width 0.4s ease, opacity 0.3s;
	}

	.progress-times {
		display: flex; justify-content: space-between;
		font-size: 10px; font-family: var(--mono);
	}

	.player-controls {
		display: flex; align-items: center; justify-content: center;
		gap: 12px;
	}

	.p-btn {
		all: unset; box-sizing: border-box;
		width: 36px; height: 36px;
		display: flex; align-items: center; justify-content: center;
		border-radius: 50%; cursor: pointer;
		color: var(--muted); font-size: 14px;
		background: var(--bg-raised);
		border: 1px solid var(--border);
		transition: color 0.2s, border-color 0.2s, background 0.2s;
	}

	.p-btn:hover {
		color: var(--text); border-color: var(--muted);
	}

	.p-btn.play {
		width: 42px; height: 42px;
		background: var(--accent); border-color: var(--accent);
		color: var(--bg-deep); font-size: 16px;
	}

	.p-btn.play:hover { opacity: 0.9; }

	.loaded-rows { display: none; }
	.loaded-rows.visible { display: block; }

	.status-card { font-size: 13px; padding-bottom: 32px; }

	.status-row {
		display: flex; align-items: center; gap: 10px;
		padding: 8px 0;
		border-bottom: 1px solid var(--border);
	}

	.status-row:last-child { border-bottom: none; }

	.status-dot {
		width: 8px; height: 8px; border-radius: 50%; flex-shrink: 0;
	}

	.status-dot.green { background: var(--green, #9ece6a); box-shadow: 0 0 6px rgba(158,206,106,0.4); }
	.status-dot.orange { background: var(--orange); box-shadow: 0 0 6px rgba(224,175,104,0.4); }

	.repeat-section { max-width: 1200px; margin: 0 auto; padding: 48px 32px 48px; }

	.section-intro { margin-bottom: 20px; }
	.section-intro h2 {
		font-size: 22px; font-weight: 700; letter-spacing: -0.5px;
		margin-bottom: 6px;
	}

	.repeat-controls {
		display: flex; gap: 24px;
		background: var(--bg-surface); border: 1px solid var(--border);
		border-radius: var(--radius); padding: 16px 20px;
		margin-bottom: 16px;
	}

	.repeat-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; }

	.repeat-card {
		background: var(--bg-surface); border: 1px solid var(--border);
		border-radius: var(--radius); overflow: hidden;
	}

	.table-head {
		display: grid; grid-template-columns: 32px 1fr 1fr 60px;
		gap: 12px; padding: 10px 16px;
		border-bottom: 1px solid var(--border);
	}

	.th {
		font-size: 10px; text-transform: uppercase;
		letter-spacing: 0.5px; color: var(--dim); font-weight: 600;
	}

	.table-row {
		display: grid; grid-template-columns: 32px 1fr 1fr 60px;
		gap: 12px; padding: 10px 16px; align-items: center; font-size: 13px;
	}

	.role-badge {
		font-size: 10px; padding: 2px 8px; border-radius: 6px;
		background: var(--bg-raised); color: var(--accent); font-weight: 500;
	}

	.feed-head {
		font-size: 11px; text-transform: uppercase;
		letter-spacing: 0.5px; color: var(--dim);
		font-weight: 600; padding: 14px 16px 10px;
		border-bottom: 1px solid var(--border);
	}

	.feed-row {
		display: flex; align-items: center; gap: 10px;
		padding: 10px 16px; font-size: 13px;
	}

	.feed-text { flex: 1; min-width: 0; }
	.feed-text strong { display: block; margin-bottom: 2px; }

	.footer {
		text-align: center; padding: 48px 24px 40px;
		font-family: var(--mono); font-size: 12px; color: var(--dim);
	}

	.footer a {
		color: var(--muted); border-bottom: 1px solid var(--border);
		padding-bottom: 1px; transition: color 0.2s, border-color 0.2s;
	}

	.footer a:hover { color: var(--accent); border-color: var(--accent); }
	.footer-sep { margin: 0 12px; }

	@keyframes fade-up {
		from { opacity: 0; transform: translateY(16px); }
		to { opacity: 1; transform: translateY(0); }
	}

	.hero { animation: fade-up 0.6s ease both; }
	.controls-bar { animation: fade-up 0.6s ease 0.1s both; }
	.grid phantom-ui:nth-child(1)  { animation: fade-up 0.5s ease 0.15s both; }
	.grid phantom-ui:nth-child(2)  { animation: fade-up 0.5s ease 0.20s both; }
	.grid phantom-ui:nth-child(3)  { animation: fade-up 0.5s ease 0.25s both; }
	.grid phantom-ui:nth-child(4)  { animation: fade-up 0.5s ease 0.30s both; }
	.grid phantom-ui:nth-child(5)  { animation: fade-up 0.5s ease 0.35s both; }
	.grid phantom-ui:nth-child(6)  { animation: fade-up 0.5s ease 0.40s both; }
	.grid phantom-ui:nth-child(7)  { animation: fade-up 0.5s ease 0.45s both; }
	.grid phantom-ui:nth-child(8)  { animation: fade-up 0.5s ease 0.50s both; }
	.grid phantom-ui:nth-child(9)  { animation: fade-up 0.5s ease 0.55s both; }
	.grid phantom-ui:nth-child(10) { animation: fade-up 0.5s ease 0.60s both; }
	.grid phantom-ui:nth-child(11) { animation: fade-up 0.5s ease 0.65s both; }
	.repeat-section { animation: fade-up 0.5s ease 0.70s both; }

	[data-theme="light"] {
		--bg-deep: #f5f5f7;
		--bg-surface: #ffffff;
		--bg-raised: #ebebef;
		--border: #d4d4d8;
		--border-dim: #e4e4e8;
		--text: #1a1b26;
		--muted: #4b4f6a;
		--dim: #6e7290;
		--accent: #3b5ce4;
		--pink: #e5484d;
		--green: #2f8a43;
		--orange: #c4912e;
	}

	[data-theme="light"] .grain { display: none; }

	[data-theme="light"] body::before {
		background: radial-gradient(ellipse at 50% 0%, rgba(74,108,247,0.04) 0%, transparent 70%);
	}

	[data-theme="light"] .controls-bar {
		background: rgba(245,245,247,0.9);
	}

	[data-theme="light"] .back-link {
		background: rgba(245,245,247,0.8);
	}

	[data-theme="light"] .toggle {
		background: var(--bg-surface);
	}

	[data-theme="light"] .toggle-thumb { background: white; }

	@media (max-width: 960px) {
		.grid { columns: 2; }
	}

	@media (max-width: 640px) {
		.back-link span { display: none; }
		.hero { padding: 40px 16px 28px; }
		.hero-sub { font-size: 14px; }
		.controls-bar { padding: 12px 16px; }
		.controls-inner { gap: 14px; }
		.showcase { padding: 20px 16px 0; }
		.grid { columns: 1; }
		.repeat-section { padding: 32px 16px 32px; }
		.repeat-grid { grid-template-columns: 1fr; }
		input[type="range"] { width: 90px; }
	}
</style>

</body>
</html>
