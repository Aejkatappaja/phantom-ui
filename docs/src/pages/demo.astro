<script is:inline src="/phantom-ui/phantom-ui.cdn.js"></script>
<script is:inline>
document.addEventListener("DOMContentLoaded", function () {
	var els = document.querySelectorAll(".target");
	var countEls = document.querySelectorAll(".count-target");
	var allEls = document.querySelectorAll("phantom-ui");
	var btn = document.getElementById("toggle");
	var isLoading = false;
	var loadedRows = document.querySelectorAll(".loaded-rows");
	loadedRows.forEach(function (el) { el.classList.add("visible"); });

	allEls.forEach(function (el) {
		el.setAttribute("shimmer-color", "rgba(122,162,247,0.35)");
		el.setAttribute("background-color", "rgba(122,162,247,0.1)");
	});

	var ghost = document.querySelector(".dash-ghost");
	btn.addEventListener("click", function () {
		isLoading = !isLoading;
		allEls.forEach(function (el) {
			if (isLoading) el.setAttribute("loading", "");
			else el.removeAttribute("loading");
		});
		loadedRows.forEach(function (el) {
			el.classList.toggle("visible", !isLoading);
		});
		if (ghost) ghost.style.display = isLoading ? "none" : "";
		btn.classList.toggle("active", isLoading);
		btn.querySelector(".toggle-text").textContent = isLoading ? "Loading" : "Loaded";
	});

	document.querySelectorAll(".pills").forEach(function (group) {
		group.querySelectorAll(".pill").forEach(function (pill) {
			pill.addEventListener("click", function () {
				group.querySelectorAll(".pill").forEach(function (p) { p.classList.remove("active"); });
				pill.classList.add("active");
				allEls.forEach(function (el) { el.setAttribute("animation", pill.dataset.value); });
			});
		});
	});

	document.querySelectorAll(".swatches").forEach(function (group) {
		var attr = group.dataset.control;
		group.querySelectorAll(".sw").forEach(function (sw) {
			sw.addEventListener("click", function () {
				group.querySelectorAll(".sw").forEach(function (s) { s.classList.remove("active"); });
				sw.classList.add("active");
				allEls.forEach(function (el) { el.setAttribute(attr, sw.dataset.value); });
			});
		});
	});

	function slider(id, valId, suffix, attr) {
		var input = document.getElementById(id);
		var display = document.getElementById(valId);
		input.addEventListener("input", function () {
			display.textContent = input.value + suffix;
			allEls.forEach(function (el) { el.setAttribute(attr, input.value); });
		});
	}

	slider("r-dur", "v-dur", "s", "duration");
	slider("r-stag", "v-stag", "s", "stagger");
	slider("r-rev", "v-rev", "s", "reveal");
	slider("r-rad", "v-rad", "px", "fallback-radius");

	document.getElementById("r-count").addEventListener("input", function () {
		document.getElementById("v-count").textContent = this.value;
		countEls.forEach(function (el) { el.setAttribute("count", this.value); }.bind(this));
	});

	document.getElementById("r-gap").addEventListener("input", function () {
		document.getElementById("v-gap").textContent = this.value + "px";
		countEls.forEach(function (el) { el.setAttribute("count-gap", this.value); }.bind(this));
	});

	var themeBtn = document.getElementById("theme-toggle");
	themeBtn.addEventListener("click", function () {
		var html = document.documentElement;
		var isDark = html.getAttribute("data-theme") !== "light";
		var next = isDark ? "light" : "dark";
		html.setAttribute("data-theme", next);
		localStorage.setItem("starlight-theme", next);
	});
});
</script>

