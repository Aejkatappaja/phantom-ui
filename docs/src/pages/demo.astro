---
---
<html lang="en" data-theme="dark">
<script is:inline>
(function() {
	var t = localStorage.getItem('starlight-theme');
	if (t === 'light') document.documentElement.setAttribute('data-theme', 'light');
})();
</script>
<head>
	<meta charset="UTF-8" />
	<meta name="viewport" content="width=device-width, initial-scale=1.0" />
	<title>phantom-ui / demo</title>
	<meta name="description" content="Interactive demo for phantom-ui — structure-aware skeleton loader Web Component." />
	<link rel="preconnect" href="https://fonts.googleapis.com" />
	<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
	<link href="https://fonts.googleapis.com/css2?family=Sora:wght@300;400;500;600;700&family=JetBrains+Mono:wght@400;500;600&display=swap" rel="stylesheet" />
</head>
<body>

<div class="grain" aria-hidden="true"></div>

<a href="/phantom-ui/" class="back-link">
	<svg viewBox="0 0 40 48" fill="none" width="24" height="28">
		<path d="M20 2 C10 2, 4 12, 4 22 L4 36 L4 40 C6 37, 9 37, 12 40 C15 37, 18 37, 20 40 C22 37, 25 37, 28 40 C31 37, 34 37, 36 40 L36 36 L36 22 C36 12, 30 2, 20 2 Z" fill="#c0caf5"/>
		<ellipse cx="14" cy="22" rx="3.5" ry="4" fill="#0f1117"/>
		<ellipse cx="26" cy="22" rx="3.5" ry="4" fill="#0f1117"/>
		<ellipse cx="20" cy="32" rx="2.5" ry="3" fill="#0f1117"/>
	</svg>
	<span>Back to docs</span>
</a>

<section class="hero">
	<p class="hero-tag">Interactive Demo</p>
	<h1 class="hero-title">See it in action</h1>
	<p class="hero-sub">Toggle loading to watch real UI transform into perfectly-aligned skeleton placeholders.</p>
</section>

<div class="controls-bar">
	<div class="controls-inner">
		<button id="toggle" class="toggle" type="button">
			<span class="toggle-track"><span class="toggle-thumb"></span></span>
			<span class="toggle-text">Loaded</span>
		</button>

		<div class="ctrl-sep"></div>

		<div class="ctrl-group">
			<span class="ctrl-label">Animation</span>
			<div class="pills" data-control="animation">
				<button class="pill active" data-value="shimmer">shimmer</button>
				<button class="pill" data-value="pulse">pulse</button>
				<button class="pill" data-value="breathe">breathe</button>
				<button class="pill" data-value="solid">solid</button>
			</div>
		</div>

		<div class="ctrl-stack">
			<div class="ctrl-group">
				<span class="ctrl-label">Shimmer color</span>
				<div class="swatches" data-control="shimmer-color">
					<button class="sw active" data-value="rgba(122,162,247,0.35)" style="--c:#7aa2f7" title="Blue"></button>
					<button class="sw" data-value="rgba(187,154,247,0.35)" style="--c:#bb9af7" title="Purple"></button>
					<button class="sw" data-value="rgba(158,206,106,0.35)" style="--c:#9ece6a" title="Green"></button>
					<button class="sw" data-value="rgba(224,175,104,0.35)" style="--c:#e0af68" title="Orange"></button>
					<button class="sw" data-value="rgba(247,118,142,0.35)" style="--c:#f7768e" title="Pink"></button>
				</div>
			</div>
			<div class="ctrl-group">
				<span class="ctrl-label">Block color</span>
				<div class="swatches" data-control="background-color">
					<button class="sw active" data-value="rgba(122,162,247,0.1)" style="--c:#7aa2f7" title="Blue"></button>
					<button class="sw" data-value="rgba(187,154,247,0.1)" style="--c:#bb9af7" title="Purple"></button>
					<button class="sw" data-value="rgba(158,206,106,0.1)" style="--c:#9ece6a" title="Green"></button>
					<button class="sw" data-value="rgba(224,175,104,0.1)" style="--c:#e0af68" title="Orange"></button>
					<button class="sw" data-value="rgba(247,118,142,0.1)" style="--c:#f7768e" title="Pink"></button>
				</div>
			</div>
		</div>

		<div class="ctrl-stack">
			<div class="ctrl-group">
				<span class="ctrl-label">Duration <span class="ctrl-val" id="v-dur">1.5s</span></span>
				<input type="range" id="r-dur" min="0.5" max="4" step="0.1" value="1.5" />
			</div>
			<div class="ctrl-group">
				<span class="ctrl-label">Reveal <span class="ctrl-val" id="v-rev">0s</span></span>
				<input type="range" id="r-rev" min="0" max="1" step="0.05" value="0" />
			</div>
		</div>

		<div class="ctrl-stack">
			<div class="ctrl-group">
				<span class="ctrl-label">Stagger <span class="ctrl-val" id="v-stag">0s</span></span>
				<input type="range" id="r-stag" min="0" max="0.2" step="0.01" value="0" />
			</div>
			<div class="ctrl-group">
				<span class="ctrl-label">Radius <span class="ctrl-val" id="v-rad">4px</span></span>
				<input type="range" id="r-rad" min="0" max="24" step="1" value="4" />
			</div>
		</div>

		<div class="ctrl-sep"></div>

		<button id="theme-toggle" class="theme-toggle" type="button" title="Toggle theme">
			<span class="theme-slider">
				<svg class="theme-moon" width="12" height="12" viewBox="0 0 24 24" fill="currentColor"><path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/></svg>
				<svg class="theme-sun" width="12" height="12" viewBox="0 0 24 24" fill="currentColor"><circle cx="12" cy="12" r="5"/><line x1="12" y1="1" x2="12" y2="3" stroke="currentColor" stroke-width="2"/><line x1="12" y1="21" x2="12" y2="23" stroke="currentColor" stroke-width="2"/><line x1="4.22" y1="4.22" x2="5.64" y2="5.64" stroke="currentColor" stroke-width="2"/><line x1="18.36" y1="18.36" x2="19.78" y2="19.78" stroke="currentColor" stroke-width="2"/><line x1="1" y1="12" x2="3" y2="12" stroke="currentColor" stroke-width="2"/><line x1="21" y1="12" x2="23" y2="12" stroke="currentColor" stroke-width="2"/><line x1="4.22" y1="19.78" x2="5.64" y2="18.36" stroke="currentColor" stroke-width="2"/><line x1="18.36" y1="5.64" x2="19.78" y2="4.22" stroke="currentColor" stroke-width="2"/></svg>
			</span>
		</button>
	</div>
</div>

<section class="showcase">
	<phantom-ui class="target dash-shell">
		<div class="card dash">
			<div class="dash-top">
				<nav class="dash-nav" data-shimmer-ignore>
					<span class="dash-nav-item">Overview</span>
					<span class="dash-nav-item active">Analytics</span>
					<span class="dash-nav-item">Customers</span>
					<span class="dash-nav-item">Settings</span>
				</nav>
				<div class="dash-actions">
					<div class="dash-search" data-shimmer-ignore>
						<span>Search...</span>
						<span class="dash-kbd">&#8984;K</span>
					</div>
					<div class="dash-avatar-sm">
						<svg class="dash-ghost" viewBox="0 0 40 48" fill="none" width="18" height="22">
							<path d="M20 2 C10 2, 4 12, 4 22 L4 36 L4 40 C6 37, 9 37, 12 40 C15 37, 18 37, 20 40 C22 37, 25 37, 28 40 C31 37, 34 37, 36 40 L36 36 L36 22 C36 12, 30 2, 20 2 Z" fill="#c0caf5"/>
							<ellipse cx="14" cy="22" rx="3.5" ry="4" fill="#0f1117"/>
							<ellipse cx="26" cy="22" rx="3.5" ry="4" fill="#0f1117"/>
							<ellipse cx="20" cy="32" rx="2.5" ry="3" fill="#0f1117"/>
						</svg>
					</div>
				</div>
			</div>
			<div class="dash-body">
				<div class="dash-grid">
					<div class="dash-metric">
						<div class="dash-metric-label">Total Revenue</div>
						<div class="dash-metric-val">$124,592</div>
						<div class="dash-metric-change positive">+12.3%</div>
					</div>
					<div class="dash-metric">
						<div class="dash-metric-label">Active Users</div>
						<div class="dash-metric-val">8,429</div>
						<div class="dash-metric-change positive">+4.1%</div>
					</div>
					<div class="dash-metric">
						<div class="dash-metric-label">Conversion</div>
						<div class="dash-metric-val">3.24%</div>
						<div class="dash-metric-change negative">-0.8%</div>
					</div>
					<div class="dash-metric">
						<div class="dash-metric-label">Avg. Order</div>
						<div class="dash-metric-val">$68.40</div>
						<div class="dash-metric-change positive">+2.5%</div>
					</div>
				</div>
				<div class="dash-chart-area">
					<div class="dash-chart-header">
						<span>Revenue Overview</span>
						<div class="dash-chart-tabs">
							<span class="dash-chart-tab active">Week</span>
							<span class="dash-chart-tab">Month</span>
							<span class="dash-chart-tab">Year</span>
						</div>
					</div>
					<div class="dash-chart-body">
					<svg class="dash-chart" viewBox="0 0 600 160" preserveAspectRatio="none">
						<defs>
							<linearGradient id="chart-fill" x1="0" y1="0" x2="0" y2="1">
								<stop offset="0%" stop-color="#E1AF68" stop-opacity="0.15"/>
								<stop offset="100%" stop-color="#E1AF68" stop-opacity="0"/>
							</linearGradient>
						</defs>
						<path d="M0,120 C40,110 80,90 120,95 C160,100 200,60 240,55 C280,50 320,70 360,45 C400,20 440,35 480,25 C520,15 560,30 600,10 L600,160 L0,160 Z" fill="url(#chart-fill)"/>
						<polyline points="0,120 120,95 240,55 360,45 480,25 600,10" fill="none" stroke="#E1AF68" stroke-width="2" stroke-linejoin="round" stroke-linecap="round"/>
					</svg>
				</div>
				</div>
			</div>
		</div>
	</phantom-ui>

	<div class="grid">


		<phantom-ui class="target">
			<div class="card">
				<div class="card-head">
					<img class="avatar" src="https://i.pravatar.cc/96?img=68" alt="" width="48" height="48" />
					<div>
						<h3>John Doe</h3>
						<p class="muted small">Senior Engineer at Vercel</p>
					</div>
				</div>
				<p class="muted body-text">Building scalable distributed systems and mentoring junior engineers on cloud-native architecture.</p>
				<div class="tags">
					<span class="tag">Rust</span>
					<span class="tag">TypeScript</span>
					<span class="tag">Go</span>
				</div>
			</div>
		</phantom-ui>


		<phantom-ui class="target">
			<div class="stats">
				<div class="stat">
					<div class="stat-val">$48.2k</div>
					<div class="stat-lbl">Revenue</div>
				</div>
				<div class="stat">
					<div class="stat-val">2,847</div>
					<div class="stat-lbl">Users</div>
				</div>
				<div class="stat">
					<div class="stat-val">42ms</div>
					<div class="stat-lbl">Latency</div>
				</div>
				<div class="stat">
					<div class="stat-val">99.9%</div>
					<div class="stat-lbl">Uptime</div>
				</div>
			</div>
		</phantom-ui>


		<phantom-ui class="target">
			<div class="card">
				<div class="list-row">
					<img class="dot-avatar" src="https://i.pravatar.cc/64?img=33" alt="" width="32" height="32" />
					<div class="list-text">
						<strong>New deployment</strong>
						<span class="muted small">Production v2.4.1 deployed</span>
					</div>
					<span class="badge">New</span>
				</div>
				<div class="list-row">
					<img class="dot-avatar" src="https://i.pravatar.cc/64?img=15" alt="" width="32" height="32" />
					<div class="list-text">
						<strong>PR merged</strong>
						<span class="muted small">Fix auth timeout #342</span>
					</div>
				</div>
				<div class="list-row last">
					<img class="dot-avatar" src="https://i.pravatar.cc/64?img=8" alt="" width="32" height="32" />
					<div class="list-text">
						<strong>Alert resolved</strong>
						<span class="muted small">CPU back to normal on api-3</span>
					</div>
				</div>
			</div>
		</phantom-ui>


		<phantom-ui class="target">
			<div class="card">
				<img class="cover" src="https://images.unsplash.com/photo-1558494949-ef010cbdcc31?w=600&h=240&fit=crop" alt="" />
				<h3>Building Resilient Microservices</h3>
				<p class="muted small" style="margin-bottom:6px">March 28, 2026 &middot; 8 min read</p>
				<p class="muted body-text">A practical guide to circuit breakers and retry patterns that keep services running.</p>
			</div>
		</phantom-ui>


		<phantom-ui class="target">
			<div class="card pricing">
				<div class="plan-name" data-shimmer-ignore>Pro Plan</div>
				<div class="price" data-shimmer-no-children>$29<span class="muted">/mo</span></div>
				<ul class="features">
					<li>Unlimited projects</li>
					<li>Priority support</li>
					<li>Custom domains</li>
					<li>Analytics dashboard</li>
				</ul>
				<button class="cta" type="button">Get Started</button>
			</div>
		</phantom-ui>


		<phantom-ui class="target">
			<div class="card">
				<div class="comment">
					<img class="dot-avatar" src="https://i.pravatar.cc/64?img=51" alt="" width="32" height="32" />
					<div>
						<strong>Alex Rivera</strong> <span class="muted small">2h ago</span>
						<p class="muted body-text">Have you considered using a service mesh for the retry logic?</p>
					</div>
				</div>
				<div class="comment last">
					<img class="dot-avatar" src="https://i.pravatar.cc/64?img=25" alt="" width="32" height="32" />
					<div>
						<strong>Priya Sharma</strong> <span class="muted small">4h ago</span>
						<p class="muted body-text">We tried this pattern last quarter. Reduced p99 latency by 40%.</p>
					</div>
				</div>
			</div>
		</phantom-ui>


		<phantom-ui class="target">
			<div class="card chat-card">
				<div class="chat-header">
					<img class="dot-avatar" src="https://i.pravatar.cc/64?img=60" alt="" width="32" height="32" />
					<div>
						<strong data-shimmer-ignore>Team General</strong>
						<span class="muted small">3 online</span>
					</div>
				</div>
				<div class="chat-messages">
					<div class="msg msg-other">
						<img class="msg-avatar" src="https://i.pravatar.cc/48?img=33" alt="" width="24" height="24" />
						<div class="msg-bubble">
							<span class="msg-name">Alex</span>
							<p>Deployed the new API gateway. Tests are green.</p>
							<span class="msg-time muted">10:42</span>
						</div>
					</div>
					<div class="msg msg-self">
						<div class="msg-bubble self">
							<p>Nice, I'll start migrating the auth service.</p>
							<span class="msg-time muted">10:45</span>
						</div>
					</div>
					<div class="msg msg-other">
						<img class="msg-avatar" src="https://i.pravatar.cc/48?img=25" alt="" width="24" height="24" />
						<div class="msg-bubble">
							<span class="msg-name">Priya</span>
							<p>Heads up, staging DB is running slow today.</p>
							<span class="msg-time muted">10:51</span>
						</div>
					</div>
				</div>
			</div>
		</phantom-ui>


		<phantom-ui class="target">
			<div class="card metrics-card">
				<h3 class="metrics-title" data-shimmer-ignore>System Health</h3>
				<div class="metric-row">
					<div class="metric-head">
						<span class="metric-label">CPU Usage</span>
						<span class="metric-value">73%</span>
					</div>
					<div class="meter" data-shimmer-no-children><div class="meter-fill" style="width:73%"></div></div>
				</div>
				<div class="metric-row">
					<div class="metric-head">
						<span class="metric-label">Memory</span>
						<span class="metric-value">4.2 / 8 GB</span>
					</div>
					<div class="meter" data-shimmer-no-children><div class="meter-fill" style="width:52%"></div></div>
				</div>
				<div class="metric-row">
					<div class="metric-head">
						<span class="metric-label">Disk</span>
						<span class="metric-value">186 / 512 GB</span>
					</div>
					<div class="meter" data-shimmer-no-children><div class="meter-fill" style="width:36%"></div></div>
				</div>
				<div class="metric-row">
					<div class="metric-head">
						<span class="metric-label">Network</span>
						<span class="metric-value">12.4 Mbps</span>
					</div>
					<div class="meter" data-shimmer-no-children><div class="meter-fill" style="width:18%"></div></div>
				</div>
			</div>
		</phantom-ui>


		<phantom-ui class="target">
			<div class="card product-card">
				<img class="product-img" src="https://images.unsplash.com/photo-1545454675-3531b543be5d?w=600&h=280&fit=crop" alt="" />
				<div class="product-body">
					<span class="product-cat muted small">Audio Equipment</span>
					<h3 class="product-name">Studio Monitor Pro 8"</h3>
					<div class="stars">
						<span class="star filled">&#9733;</span><span class="star filled">&#9733;</span><span class="star filled">&#9733;</span><span class="star filled">&#9733;</span><span class="star dim">&#9733;</span>
						<span class="star-count muted small">(128)</span>
					</div>
					<div class="product-footer">
						<span class="product-price">$349</span>
						<button class="cta-sm" type="button">Add to cart</button>
					</div>
				</div>
			</div>
		</phantom-ui>


		<phantom-ui class="target">
			<div class="card player-card">
				<div class="player-top">
					<img class="album-art" src="https://picsum.photos/seed/phantom-album/128/128" alt="" />
					<div class="player-info">
						<h3 class="player-song">Midnight City</h3>
						<p class="muted small">M83 &middot; Hurry Up, We're Dreaming</p>
					</div>
				</div>
				<div class="player-progress">
					<div class="progress-bar" data-shimmer-no-children><div class="progress-fill" style="width:65%"></div></div>
					<div class="progress-times muted small">
						<span>2:38</span>
						<span>4:03</span>
					</div>
				</div>
