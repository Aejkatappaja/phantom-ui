{
	"$schema": "https://biomejs.dev/schemas/2.4.11/schema.json",
	"assist": { "actions": { "source": { "organizeImports": "on" } } },
	"linter": {
		"enabled": true,
		"rules": {
			"recommended": true,
			"suspicious": {
				"noExplicitAny": "error"
			},
			"complexity": {
				"noImportantStyles": "off"
			}
		}
	},
	"formatter": {
		"enabled": true,
		"indentStyle": "tab",
		"lineWidth": 100
	},
	"javascript": {
		"formatter": {
			"quoteStyle": "double",
			"semicolons": "always"
		}
	},
	"files": {
		"includes": [
			"**",
			"!**/dist",
			"!**/node_modules",
			"!**/storybook-static",
			"!**/examples",
			"!**/.husky",
			"!**/.github",
			"!**/.storybook",
			"!**/.claude",
			"!**/docs",
			"!**/custom-elements.json"
		]
	}
}
